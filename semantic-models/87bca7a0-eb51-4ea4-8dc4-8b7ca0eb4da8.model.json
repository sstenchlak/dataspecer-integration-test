    "2gzn20p8poqmo9vmi6f": {
      "iri": "ApplicationProfile",
      "profiling": [
        "https://w3id.org/dsv#ApplicationProfile"
      ],
      "name": {
        "cs": "Konceptuální model",
        "en": "Application Profile"
      },
      "nameFromProfiled": "https://w3id.org/dsv#ApplicationProfile",
      "description": {
        "cs": "Konceptuální model obsahující profily tříd a vlastností různých slovníků.",
        "en": "An Application Profile identifies classes and properties from vocabularies, and class profiles and property profiles from Application profiles that are re-used in a certain usage context. It also allows specification editors to further adjust the description of re-used classes and properties for that usage context without the need to explicitly create subclasses and subproperties."
      },
      "descriptionFromProfiled": "https://w3id.org/dsv#ApplicationProfile",
      "usageNote": null,
      "usageNoteFromProfiled": null,
      "externalDocumentationUrl": null,
      "tags": [],
      "id": "2gzn20p8poqmo9vmi6f",
      "type": [
        "class-profile"
      ]
    },
