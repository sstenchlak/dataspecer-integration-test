        "https://w3id.org/dsv#PropertyValueReuse"
      ],
      "name": {
        "en": "Property Value Reuse"
      },
      "nameFromProfiled": "https://w3id.org/dsv#PropertyValueReuse",
      "description": {
        "en": "Specifies, which values of which properties of which resources are reused for the current Profile.\nE.g. reuse of profile name, reuse of class name, reuse of profile definition, reuse of profile usage note, etc."
      },
      "descriptionFromProfiled": "https://w3id.org/dsv#PropertyValueReuse",
      "usageNote": null,
